pragma solidity ^0.8.17;

import { ILiFi } from "../Interfaces/ILiFi.sol";
import { LibAsset } from "../Libraries/LibAsset.sol";
import { LibSwap } from "../Libraries/LibSwap.sol";
import { ReentrancyGuard } from "../Helpers/ReentrancyGuard.sol";
import { SwapperV2 } from "../Helpers/SwapperV2.sol";
import { Validatable } from "../Helpers/Validatable.sol";
import { InvalidConfig } from "../Errors/GenericErrors.sol";

/// @title {{properCase name}}Facet
/// @author LI.FI (https://li.fi)
/// @notice {{description}}
/// @custom:version 1.0.0
contract {{properCase name}}Facet is ILiFi, ReentrancyGuard, SwapperV2, Validatable {
    /// Storage ///

    /// @dev Example of an immutable contract address set at deploy time.
    ///      Anything that cannot be set as immutable should be set
    ///      in an init function called during a diamondCut().
    address public immutable EXAMPLE;

    /// Types ///

    /// @dev Optional bridge specific struct
    /// @param exampleParam Example parameter
    struct {{properCase name}}Data {
        string exampleParam;
    }

    /// Constructor ///

    /// @notice Initializes the {{properCase name}}Facet contract
    /// @param _example Example parameter
    constructor(address _example) {
        if (_example == address(0)) {
            revert InvalidConfig();
        }
        EXAMPLE = _example;
    }

    /// External Methods ///

    /// @notice Bridges tokens via {{properCase name}}
    /// @param _bridgeData The core information needed for bridging
    /// @param _{{camelCase name}}Data Data specific to {{properCase name}}
    function startBridgeTokensVia{{properCase name}}(
        ILiFi.BridgeData memory _bridgeData,
        {{properCase name}}Data calldata _{{camelCase name}}Data
    )
        external
        payable
        nonReentrant
        refundExcessNative(payable(msg.sender))
        validateBridgeData(_bridgeData)
        doesNotContainSourceSwaps(_bridgeData)
        doesNotContainDestinationCalls(_bridgeData)
    {
        LibAsset.depositAsset(
            _bridgeData.sendingAssetId,
            _bridgeData.minAmount
        );
        _startBridge(_bridgeData, _{{camelCase name}}Data);
    }

    /// @notice Performs a swap before bridging via {{properCase name}}
    /// @param _bridgeData The core information needed for bridging
    /// @param _swapData An array of swap related data for performing swaps before bridging
    /// @param _{{camelCase name}}Data Data specific to {{properCase name}}
    function swapAndStartBridgeTokensVia{{properCase name}}(
        ILiFi.BridgeData memory _bridgeData,
        LibSwap.SwapData[] calldata _swapData,
        {{properCase name}}Data calldata _{{camelCase name}}Data
    )
        external
        payable
        nonReentrant
        refundExcessNative(payable(msg.sender))
        containsSourceSwaps(_bridgeData)
        doesNotContainDestinationCalls(_bridgeData)
        validateBridgeData(_bridgeData)
    {
        _bridgeData.minAmount = _depositAndSwap(
            _bridgeData.transactionId,
            _bridgeData.minAmount,
            _swapData,
            payable(msg.sender)
        );
        _startBridge(_bridgeData, _{{camelCase name}}Data);
    }

    /// Internal Methods ///

    /// @dev Contains the business logic for the bridge via {{properCase name}}
    /// @param _bridgeData The core information needed for bridging
    /// @param _{{camelCase name}}Data Data specific to {{properCase name}}
    function _startBridge(
        ILiFi.BridgeData memory _bridgeData,
        // solhint-disable-next-line no-unused-vars
        {{properCase name}}Data calldata _{{camelCase name}}Data
    ) internal {
        // TODO: Implement business logic (remove the solhint-disable comment
        // above once _{{camelCase name}}Data is used)
        emit LiFiTransferStarted(_bridgeData);
    }
}
