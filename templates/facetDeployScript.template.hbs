pragma solidity ^0.8.17;

import { DeployScriptBase } from "./utils/DeployScriptBase.sol";
import { stdJson } from "forge-std/Script.sol";
import { {{properCase name}}Facet } from "lifi/Facets/{{properCase name}}Facet.sol";

contract DeployScript is DeployScriptBase {
    using stdJson for string;

    constructor() DeployScriptBase("{{properCase name}}Facet") {}

    function run()
        public
        returns ({{properCase name}}Facet deployed, bytes memory constructorArgs)
    {
        constructorArgs = getConstructorArgs();

        deployed = {{properCase name}}Facet(deploy(type({{properCase name}}Facet).creationCode));
    }

    function getConstructorArgs() internal override returns (bytes memory) {
        // If your facet doesn't have a constructor or it doesn't take any arguments, you can remove this function
        string memory path = string.concat(root, "/config/{{kebabCase name}}.json");

        // If you need to read an address from your config file that is supposed to be a contract,
        // use the following helper which makes sure that the address contains code
        // (it also has optional flags for allowing address(0) or EOA addresses):
        address example = _getConfigContractAddress(
            path,
            string.concat(".example.", network)
        );

        return abi.encode(example);
    }
}
